{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hermai",
  "colors": {
    "primary": "#0A1410",
    "light": "#F2EDDF",
    "dark": "#0A1410"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/how-hermai-works",
              "concepts/hosted-fetch",
              "concepts/schemas",
              "concepts/catalog",
              "concepts/actions",
              "concepts/mcp",
              "concepts/credits-and-usage",
              "concepts/api-keys"
            ]
          }
        ]
      },
      {
        "language": "zh-Hant",
        "groups": [
          {
            "group": "開始使用",
            "pages": [
              "zh-Hant/index",
              "zh-Hant/quickstart"
            ]
          },
          {
            "group": "核心概念",
            "pages": [
              "zh-Hant/concepts/how-hermai-works",
              "zh-Hant/concepts/schemas",
              "zh-Hant/concepts/catalog",
              "zh-Hant/concepts/actions",
              "zh-Hant/concepts/credits-and-usage",
              "zh-Hant/concepts/api-keys"
            ]
          }
        ]
      },
      {
        "language": "zh-Hans",
        "groups": [
          {
            "group": "开始使用",
            "pages": [
              "zh-Hans/index",
              "zh-Hans/quickstart"
            ]
          },
          {
            "group": "核心概念",
            "pages": [
              "zh-Hans/concepts/how-hermai-works",
              "zh-Hans/concepts/schemas",
              "zh-Hans/concepts/catalog",
              "zh-Hans/concepts/actions",
              "zh-Hans/concepts/credits-and-usage",
              "zh-Hans/concepts/api-keys"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Homepage",
          "href": "https://hermai.ai",
          "icon": "globe"
        },
        {
          "anchor": "Blog",
          "href": "https://hermai.ai/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/wordmark-light.svg",
    "dark": "/logo/wordmark-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@hermai.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://hermai.ai/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/hermai-ai"
    }
  }
}
